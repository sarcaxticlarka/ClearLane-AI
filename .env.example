GROQ_API_KEY=
DATABASE_URL=postgresql://user:password@localhost:5432/clearlane
VITE_API_BASE_URL=http://localhost:8000

# Only set these on the deployed Render (or similar free-tier) instance, to its own
# public URL - keeps the service awake by self-pinging /api/health every 10 min.
# Leave both unset locally; the keepalive loop no-ops if SELF_PING_URL is empty.
SELF_PING_URL=
SELF_PING_INTERVAL_SECONDS=600
